# Copy this file to `.env` and fill it in. `.env` is gitignored — never commit it.

# --- CouchDB credentials ---
COUCHDB_USER=obsidian
COUCHDB_PASSWORD=change-me-to-a-long-random-string

# --- Shared-VM safety ---
# BIND_ADDR is the host address CouchDB's port is published on.
# Set it to THIS VM's Tailscale IP (run: tailscale ip -4) so tailnet devices can reach it
# while the public internet cannot. scripts/setup-vm.sh fills this in automatically.
# Leave 127.0.0.1 only for local-only testing.
BIND_ADDR=127.0.0.1

# Change only if 5984 is already used by something else on this VM.
COUCHDB_PORT=5984
